# =============================================================================
# SkillLens Evaluation — Environment Template
# Copy this file to `.env` and fill in your own values. Never commit `.env`.
# =============================================================================

# ── Anthropic LLM endpoint (used by the judge and scheme-generation modules) ─
# `core.llm_client.call_api` reads ANTHROPIC_API_KEY when no api_key is passed.
# `BaseConfig.API_BASE_URL` defaults to https://api.anthropic.com but can be
# overridden if you proxy through a compatible gateway.
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── OpenAI-compatible endpoint (used by the Codex/OpenAI agent runs) ────────
# `smoke_codex_run.py` and Harbor's openai-backed agents read these. The
# Codex Responses API uses WebSocket, so OPENAI_BASE_URL is ignored for Codex
# specifically — set it only if you also call HTTP-based OpenAI endpoints.
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5

# ── SkillLens repo root ─────────────────────────────────────────────────────
# Auto-detected from config.py if unset. Set explicitly when running the
# modules from a directory other than the repo root.
SKILLLENS_ROOT=

# ── Harbor framework install location (clone of anonyy-coder/harbor) ────────
# Path to the Harbor checkout used for sandboxed task execution.
HARBOR_HOME=/path/to/harbor

# ── Codex agent skill register location ─────────────────────────────────────
# Harbor uses this directory to install the Codex CLI assets into trial
# sandboxes. Typically points at <HARBOR_HOME>/codex.
CODEX_HOME=/path/to/harbor/codex
